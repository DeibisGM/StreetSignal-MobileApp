# StreetSignal Mobile App - Optional environment notes
#
# This project is bare React Native, so API_BASE_URL is defined in
# src/constants/index.ts by default.
# Use this file only if you add your own env loader later.

# Backend base URL. Keep the /api suffix if you wire a custom loader.
API_BASE_URL=http://10.0.2.2:5000/api

# --- Per-environment examples ---
# Development (Android emulator):   API_BASE_URL=http://10.0.2.2:5000/api
# Development (iOS simulator):      API_BASE_URL=http://localhost:5000/api
# Development (physical device):    API_BASE_URL=http://192.168.x.x:5000/api
# Staging:                          API_BASE_URL=https://api-staging.streetsignal.example.com/api
# Production:                       API_BASE_URL=https://api.streetsignal.example.com/api
