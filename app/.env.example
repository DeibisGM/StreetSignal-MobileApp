# StreetSignal Mobile App — Environment Variables
#
# Copy this file to .env and fill in the values for your target environment.
# To enable process.env resolution in Metro/Babel, install react-native-dotenv:
#   npm install --save-dev react-native-dotenv
# Then add it to babel.config.js:
#   plugins: [['module:react-native-dotenv', { moduleName: '@env', path: '.env' }]]

# Backend base URL (no trailing slash, no /api suffix — already included in client)
EXPO_PUBLIC_API_URL=http://10.0.2.2:5000/api

# --- Per-environment examples ---
# Development (Android emulator):   EXPO_PUBLIC_API_URL=http://10.0.2.2:5000/api
# Development (iOS simulator):      EXPO_PUBLIC_API_URL=http://localhost:5000/api
# Development (physical device):    EXPO_PUBLIC_API_URL=http://192.168.x.x:5000/api
# Staging:                          EXPO_PUBLIC_API_URL=https://api-staging.streetsignal.example.com/api
# Production:                       EXPO_PUBLIC_API_URL=https://api.streetsignal.example.com/api
